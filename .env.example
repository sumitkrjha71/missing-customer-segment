# ─────────────────────────────────────────────────────────────
# Customer Segment Assignment — environment
# Copy to `.env` for local dev. In prod, set these in Vercel.
# ─────────────────────────────────────────────────────────────

# Postgres (Neon).
#   DATABASE_URL → POOLED connection. Used for every runtime query.
#                  On Neon, the hostname contains "-pooler".
#   DIRECT_URL   → DIRECT (non-pooled) connection. Used only by Prisma
#                  migrations during the Vercel build. Same DB, same credentials,
#                  just the hostname WITHOUT "-pooler".
# Locally you can leave DIRECT_URL unset and Prisma will use DATABASE_URL.
DATABASE_URL="postgresql://user:password@localhost:5432/segment_ops?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/segment_ops?schema=public"

# Auth.js / NextAuth v5
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-32-byte-random-string"
# Google OAuth (console.cloud.google.com → Credentials → OAuth client)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Only emails on this domain may sign in.
ALLOWED_EMAIL_DOMAIN="spyne.ai"
# Comma-separated emails granted the ADMIN role (can trigger sync, manage users).
ADMIN_EMAILS=""

# Metabase public question that returns the unresolved-segment rows.
#
# IMPORTANT: use the .csv endpoint, not .json.
# Metabase caps public-question .json responses at 2,000 rows, which silently
# drops large enterprises. The .csv endpoint caps near 1,000,000 rows. Same
# question, same UUID, different extension — the ingestion auto-detects format.
METABASE_QUESTION_URL="https://metabase.spyne.ai/public/question/76e26fc0-8dfc-44e6-915f-c0b3a5f3d40d.csv"

# Shared secret protecting /api/sync from the public. Vercel Cron sends it as
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET="replace-me-with-a-random-string"

# Optional: public base URL of the app (used for absolute links). Vercel sets
# VERCEL_URL automatically; this is only needed for local dev convenience.
# Leave UNSET in dev — NextAuth derives the origin from the incoming request,
# which is what makes port 3001 (see `npm run dev` script) work transparently.
# NEXTAUTH_URL="http://localhost:3001"
